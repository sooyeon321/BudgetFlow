# BudgetFlow LLM Service 환경변수
# 실제 값을 채운 뒤 .env로 복사해서 사용하세요
# .env는 .gitignore에 포함되어 있어 커밋되지 않습니다

# AWS 리전 (학교 계정 RestrictRegionSeoul 정책으로 서울 고정)
AWS_REGION=ap-northeast-2

# AWS 자격증명 (AWS Academy라면 콘솔 "AWS Details"에서 복사)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=        # AWS Academy 임시 자격증명 사용 시 필요

# S3 버킷 (영수증 이미지 저장)
S3_BUCKET_NAME=2026-inha-cc-04-s3

# Express 서버 포트
PORT=4000
